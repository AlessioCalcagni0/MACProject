<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Usiamo MaterialComponents per supportare CardView e Button moderni -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">#00BFFF</item>
        <item name="colorPrimaryDark">#0086B3</item>
        <item name="colorAccent">#00BFFF</item>

        <!-- Background e Status Bar -->
        <item name="android:windowBackground">@color/brand_black</item>
        <item name="android:statusBarColor">@color/brand_black</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Default Text Color -->
        <item name="android:textColor">@color/white</item>

        <!-- Material Dialog Theme -->
        <item name="materialAlertDialogTheme">@style/MaterialAlertDialog_Rounded</item>
    </style>

    <!-- Style per Dialog Arrotondati e Scuri -->
    <style name="MaterialAlertDialog_Rounded" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Rounded</item>
        <item name="android:background">#1A1A1A</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MaterialComponents.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.MaterialComponents.Button.TextButton.Dialog</item>
    </style>

    <style name="Widget.MaterialComponents.Button.TextButton.Dialog" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#00BFFF</item>
    </style>

    <style name="ShapeAppearance.Rounded" parent="">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Style per NumberPicker con testo bianco -->
    <style name="NumberPickerWhite">
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:editTextColor">#FFFFFF</item>
        <item name="android:textSize">22sp</item>
    </style>

    <!-- Style per rendere ShapeableImageView circolare -->
    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>