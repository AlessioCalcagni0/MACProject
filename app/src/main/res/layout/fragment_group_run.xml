<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="120dp">

            <!-- Mappa -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMap"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_margin="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.gms.maps.MapView
                    android:id="@+id/groupMapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Timer -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/cardMap">

                <TextView
                    android:id="@+id/tvGroupRunTimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="00:00:00"
                    android:textColor="#212121"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Sezione Partecipanti -->
            <TextView
                android:id="@+id/tvLabelParticipants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="Participants"
                android:textColor="#757575"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardTimer" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvParticipantsStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/tvLabelParticipants" />

            <!-- Sezione Foto Carosello - Dimensioni Raddoppiate -->
            <TextView
                android:id="@+id/tvLabelPhotos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="Run photos"
                android:textColor="#757575"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvParticipantsStats" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGroupPhotos"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="8dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvLabelPhotos" />

            <!-- Azioni -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fabAddPhoto"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:text="Take a picture"
                android:backgroundTint="#4CAF50"
                android:textColor="@android:color/white"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconGravity="textStart"
                app:iconTint="@android:color/white"
                app:layout_constraintTop_toBottomOf="@id/rvGroupPhotos" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStopGroupRun"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="16dp"
        android:layout_gravity="bottom"
        android:text="FINISH RUN"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#E53935"
        app:cornerRadius="32dp"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:iconGravity="textStart" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
