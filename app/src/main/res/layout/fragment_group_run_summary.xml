<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSummaryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Riassunto Corsa"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Card Esito Obiettivo -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGoalResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:strokeWidth="2dp"
            app:strokeColor="#4CAF50"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tvGoalStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OBIETTIVO RAGGIUNTO! 🎉"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>
                <TextView
                    android:id="@+id/tvGoalDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hai superato il tuo obiettivo!"
                    android:textSize="14sp"
                    android:textColor="#666666"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card Durata Totale -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGlobalStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvSummaryDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Durata Totale: 00:00:00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#6200EE"
                    android:gravity="center"/>

                <GridLayout
                    android:id="@+id/gridSingleStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:columnCount="2"
                    android:visibility="gone">

                    <TextView android:id="@+id/tvSummaryTotalDistance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Distanza: 0.0 km"
                        android:textSize="16sp" />

                    <TextView android:id="@+id/tvSummaryTotalCalories"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Calorie: 0 kcal"
                        android:textSize="16sp" />

                    <TextView android:id="@+id/tvSummaryAvgSpeed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Vel. Media: 0.0 km/h"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"/>
                </GridLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvStatsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dettagli Partecipanti"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSummaryStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/tvPhotosHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto della Corsa"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSummaryPhotos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:nestedScrollingEnabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseSummary"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="TORNA ALLA HOME"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="32dp"
            android:backgroundTint="#6200EE"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
