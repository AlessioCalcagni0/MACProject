<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="70dp"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/tvHour"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:00"
        android:textColor="#E0E0E0"
        android:textSize="13sp" />

    <ImageView
        android:id="@+id/ivWeatherIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_weather_sunny"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvHourlyTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="20°"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Nuovo View custom per il grafico con segmenti -->
    <com.example.myapplication.ui.home.RainGraphView
        android:id="@+id/viewRainGraph"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivPrecipIcon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_water_drop"
            app:tint="#B0FFFFFF" />

        <TextView
            android:id="@+id/tvPrecipitation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="10%"
            android:textColor="#B0FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
