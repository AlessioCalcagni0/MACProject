<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/viewUserIndicator"
                android:layout_width="8dp"
                android:layout_height="32dp"
                android:background="#2196F3"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/tvParticipantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvParticipantDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:drawableStart="@android:drawable/ic_menu_directions"
            android:drawablePadding="12dp"
            android:text="Distance: 0.00 km"
            android:textColor="#212121"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvParticipantCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:drawableStart="@drawable/ic_goal_calories"
            android:drawablePadding="12dp"
            android:text="Calories = 0 kcal"
            android:textColor="#212121"
            android:textSize="18sp"
            app:drawableTint="#FF5722" />

        <TextView
            android:id="@+id/tvParticipantSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_run"
            android:drawablePadding="12dp"
            android:text="Average speed = 0.0 km/h"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold"
            app:drawableTint="#4CAF50" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
